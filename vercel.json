{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/process-go.ts": {
      "maxDuration": 30,
      "memory": 512,
      "experimentalTriggers": [
        { "type": "queue/v2beta", "topic": "go-processing" }
      ]
    }
  },
  "routes": [
    { "src": "/api/process-go", "dest": "/api/process-go.ts" },
    { "src": "/api/(.*)", "dest": "/api/index.ts" }
  ]
}
