{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/process-go.ts": {
      "maxDuration": 30,
      "memory": 512,
      "experimentalTriggers": [
        { "type": "queue/v2beta", "topic": "go-processing" }
      ]
    }
  },
  "rewrites": [
    { "source": "/api/process-go", "destination": "/api/process-go" },
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
